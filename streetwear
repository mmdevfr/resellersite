<title>StreetWearPlug — @916sellss</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d0d;
  --white:#f5f5f0;
  --yellow:#ffe600;
  --pink:#ff2d78;
  --cyan:#00f0ff;
  --orange:#ff6b00;
  --green:#00ff7f;
  --gray:#1a1a1a;
  --gray2:#252525;
  --muted:#666;
  --tick-h:32px;
  --nav-h:62px;
}

html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:'Space Grotesk',sans-serif;min-height:100vh;overflow-x:hidden}

/* ── TICKER ── */
.ticker{
  position:fixed;top:0;left:0;right:0;height:var(--tick-h);
  background:var(--yellow);overflow:hidden;display:flex;align-items:center;
  z-index:1100;border-bottom:2px solid #000;
}
.ticker-track{display:flex;gap:0;animation:tick 28s linear infinite;white-space:nowrap;will-change:transform}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ticker-item{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:13px;
  letter-spacing:2px;text-transform:uppercase;color:#000;
  padding:0 20px;border-right:2px solid rgba(0,0,0,0.2);flex-shrink:0;
  display:flex;align-items:center;height:var(--tick-h);
}
.ticker-dot{color:var(--pink);margin:0 8px;font-size:16px}

/* ── NAV ── */
nav{
  position:fixed;top:var(--tick-h);left:0;right:0;height:var(--nav-h);
  background:#000;border-bottom:3px solid var(--yellow);
  z-index:1000;display:flex;align-items:center;padding:0 16px;gap:12px;
}
.nav-logo{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;
  font-size:28px;letter-spacing:1px;color:var(--white);text-decoration:none;
  flex-shrink:0;line-height:1;text-transform:uppercase;
}
.nav-logo .plug{color:var(--yellow);
  text-shadow: 2px 2px 0 var(--pink);
}

.nav-scroll-wrap{display:flex;align-items:center;flex:1;min-width:0;gap:4px}
.nav-arrow{
  background:var(--gray2);border:1px solid #333;color:var(--white);
  cursor:pointer;width:24px;height:24px;border-radius:4px;font-size:14px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:background .15s;
}
.nav-arrow:hover{background:var(--yellow);color:#000}

.nav-links{display:flex;align-items:center;gap:3px;overflow-x:auto;scrollbar-width:none;flex:1;scroll-behavior:smooth}
.nav-links::-webkit-scrollbar{display:none}

.nav-btn{
  background:none;border:2px solid transparent;
  color:var(--muted);font-family:'Barlow Condensed',sans-serif;font-weight:700;
  font-size:12px;letter-spacing:1.5px;text-transform:uppercase;
  padding:4px 10px;border-radius:4px;white-space:nowrap;cursor:pointer;
  transition:all .15s;
}
.nav-btn:hover{color:var(--white);border-color:#333}
.nav-btn.active{color:#000;background:var(--yellow);border-color:var(--yellow)}

.ig-btn{
  display:flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);
  color:#fff;text-decoration:none;padding:7px 14px;border-radius:4px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;
  letter-spacing:1px;text-transform:uppercase;flex-shrink:0;
  border:2px solid transparent;transition:all .15s;
}
.ig-btn:hover{border-color:var(--white);transform:scale(1.03)}
.ig-btn svg{width:14px;height:14px}

.hamburger{display:none;background:none;border:2px solid #333;color:#fff;cursor:pointer;padding:4px 8px;border-radius:4px}

/* ── MOBILE NAV ── */
.mobile-nav{
  display:none;position:fixed;
  top:calc(var(--tick-h) + var(--nav-h));left:0;right:0;
  background:#000;border-bottom:3px solid var(--yellow);
  z-index:999;flex-direction:column;padding:10px;gap:4px;
  max-height:70vh;overflow-y:auto;
}
.mobile-nav.open{display:flex}
.mobile-nav .nav-btn{font-size:14px;padding:10px 14px;text-align:left;border-color:#1f1f1f}

/* ── MAIN ── */
main{padding-top:calc(var(--tick-h) + var(--nav-h))}

/* ── HERO ── */
.hero{
  min-height:85vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;padding:60px 24px 48px;
  position:relative;overflow:hidden;
}

/* graffiti spray background blobs */
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 50%, rgba(255,230,0,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 50% 35% at 80% 40%, rgba(255,45,120,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 45% 45% at 50% 80%, rgba(0,240,255,0.06) 0%, transparent 60%);
  pointer-events:none;
}

/* grunge texture overlay */
.hero::after{
  content:'';position:absolute;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;opacity:.4;
}

.hero-tag{
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;
  letter-spacing:4px;text-transform:uppercase;
  color:var(--yellow);background:#000;border:2px solid var(--yellow);
  padding:4px 14px;border-radius:2px;margin-bottom:20px;display:inline-block;
  position:relative;z-index:1;
}

.hero-title{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;
  font-size:clamp(80px,16vw,180px);line-height:.88;
  text-transform:uppercase;position:relative;z-index:1;
  margin-bottom:6px;
}
.hero-title .line1{
  color:var(--white);
  -webkit-text-stroke:2px var(--white);
  display:block;
}
.hero-title .line2{
  color:transparent;
  -webkit-text-stroke:3px var(--yellow);
  display:block;letter-spacing:-2px;
}
.hero-title .line3{
  color:var(--pink);
  display:block;font-size:clamp(40px,8vw,90px);
  -webkit-text-stroke:0px;letter-spacing:8px;
}

.hero-sub{
  font-size:12px;letter-spacing:3px;text-transform:uppercase;
  color:var(--muted);margin:20px 0 32px;position:relative;z-index:1;
}
.hero-sub span{color:var(--cyan);font-weight:700}

.hero-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;position:relative;z-index:1}

.btn-primary{
  display:flex;align-items:center;gap:8px;
  background:var(--yellow);color:#000;
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;
  letter-spacing:2px;text-transform:uppercase;
  padding:12px 28px;border-radius:3px;text-decoration:none;border:none;cursor:pointer;
  transition:all .15s;box-shadow:4px 4px 0 var(--pink);
}
.btn-primary:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--pink)}

.btn-outline{
  display:flex;align-items:center;gap:8px;
  background:transparent;color:var(--white);
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;
  letter-spacing:2px;text-transform:uppercase;
  padding:12px 28px;border-radius:3px;text-decoration:none;
  border:2px solid var(--white);cursor:pointer;
  transition:all .15s;
}
.btn-outline:hover{background:var(--white);color:#000}

/* ── SECTION ── */
.section{display:none;padding:0 20px 80px;max-width:1400px;margin:0 auto}
.section.active{display:block}

/* ── SECTION HEADER ── */
.sec-hdr{
  display:flex;align-items:center;gap:16px;
  margin-bottom:28px;padding:20px 0 16px;
  border-bottom:3px solid var(--yellow);
}
.sec-badge{
  background:var(--yellow);color:#000;
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:10px;
  letter-spacing:2px;text-transform:uppercase;padding:3px 10px;border-radius:2px;
}
.sec-title{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;
  font-size:clamp(32px,5vw,52px);text-transform:uppercase;color:var(--white);
  letter-spacing:1px;
}
.sec-price{font-size:12px;color:var(--cyan);font-weight:700;letter-spacing:1px;margin-left:auto}

/* ── EMBED ── */
.sheet-embed{
  width:100%;height:80vh;
  border:3px solid var(--yellow);border-radius:4px;
  background:#111;
}

.embed-note{
  display:flex;align-items:center;gap:10px;
  background:rgba(255,230,0,0.06);border:1px solid rgba(255,230,0,0.2);
  border-radius:4px;padding:12px 16px;margin-bottom:16px;
  font-size:12px;color:var(--muted);letter-spacing:.5px;
}
.embed-note strong{color:var(--yellow)}

/* ── HOW TO ORDER ── */
.hto-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:40px}
.info-box{
  background:var(--gray);border:2px solid #2a2a2a;border-radius:4px;
  padding:24px;
}
.info-box h3{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:13px;
  letter-spacing:3px;text-transform:uppercase;color:var(--yellow);
  margin-bottom:14px;border-bottom:1px solid #2a2a2a;padding-bottom:10px;
}
.info-box ul{list-style:none;display:flex;flex-direction:column;gap:8px}
.info-box li{font-size:13px;color:#bbb;line-height:1.5;display:flex;gap:8px}
.info-box li::before{content:'▸';color:var(--yellow);flex-shrink:0}

.steps{display:flex;flex-direction:column;gap:0}
.step{
  display:flex;gap:20px;padding:24px 0;
  border-bottom:1px solid #1e1e1e;
}
.step:last-child{border-bottom:none}
.step-n{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;
  font-size:56px;line-height:1;flex-shrink:0;width:52px;
  color:transparent;-webkit-text-stroke:2px var(--yellow);
}
.step h3{
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;
  letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;color:var(--white);
}
.step p{font-size:13px;color:var(--muted);line-height:1.7}
.step a{color:var(--pink);text-decoration:none;font-weight:600}
.step a:hover{text-decoration:underline}

/* ── BRAND TABS (inside sections) ── */
.brand-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px}
.brand-tab{
  background:var(--gray2);border:2px solid #2a2a2a;
  color:var(--muted);font-family:'Barlow Condensed',sans-serif;font-weight:700;
  font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
  padding:5px 12px;border-radius:3px;cursor:pointer;transition:all .15s;
}
.brand-tab.on{background:var(--yellow);color:#000;border-color:var(--yellow)}
.brand-tab:hover:not(.on){color:var(--white);border-color:#444}

/* ── PRODUCT GRID ── */
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}

.pcard{
  background:var(--gray);border:2px solid #222;border-radius:4px;
  overflow:hidden;cursor:pointer;transition:transform .2s,border-color .2s;
  position:relative;
}
.pcard:hover{transform:translateY(-4px);border-color:var(--yellow)}
.pcard:hover .pcard-overlay{opacity:1}

.pcard-overlay{
  position:absolute;inset:0;background:rgba(255,230,0,0.06);
  opacity:0;transition:opacity .2s;pointer-events:none;z-index:1;
}

.pimg{
  aspect-ratio:1;background:var(--gray2);
  display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;
}
.pimg img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
.pcard:hover .pimg img{transform:scale(1.06)}
.pimg-ph{
  display:flex;flex-direction:column;align-items:center;gap:10px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;
  letter-spacing:2px;text-transform:uppercase;color:#2e2e2e;
}
.pimg-ph svg{width:32px;height:32px;opacity:.3}

.badge{
  position:absolute;top:8px;left:8px;
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:10px;
  letter-spacing:1.5px;text-transform:uppercase;padding:3px 8px;border-radius:2px;
}
.badge-in{background:var(--green);color:#000}
.badge-out{background:var(--pink);color:#fff}

.pinfo{padding:12px 14px 14px}
.pname{
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;
  text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;line-height:1.3;
  color:var(--white);
}
.pprice{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;
  font-size:24px;color:var(--yellow);letter-spacing:1px;
}
.ptags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.ptag{
  font-size:10px;color:var(--muted);background:#1e1e1e;
  padding:3px 7px;border-radius:2px;border:1px solid #2a2a2a;
  font-weight:500;letter-spacing:.5px;
}

/* size grid */
.size-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;margin-top:8px}
.sz{
  font-size:10px;text-align:center;padding:4px 2px;border-radius:2px;
  font-weight:700;letter-spacing:.5px;border:1px solid #2a2a2a;
  font-family:'Barlow Condensed',sans-serif;font-size:11px;
}
.sz-ok{background:rgba(0,255,127,0.1);color:var(--green);border-color:rgba(0,255,127,0.2)}
.sz-no{background:rgba(255,45,120,0.08);color:#444;border-color:#1e1e1e;text-decoration:line-through}
.sz-low{background:rgba(255,107,0,0.1);color:var(--orange);border-color:rgba(255,107,0,0.2)}

/* section divider label */
.cat-label{
  grid-column:1/-1;
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:11px;
  letter-spacing:3px;text-transform:uppercase;color:var(--pink);
  padding:16px 0 8px;border-bottom:1px solid #1e1e1e;margin-bottom:4px;
  display:flex;align-items:center;gap:12px;
}
.cat-label::after{content:'';flex:1;height:1px;background:#1e1e1e}

@media(max-width:768px){
  .nav-links{display:none}
  .hamburger{display:block}
  .hto-grid{grid-template-columns:1fr}
  .pgrid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px}
  .size-grid{grid-template-columns:repeat(2,1fr)}
  nav{padding:0 12px}
  .section{padding:0 14px 60px}
  .hero{min-height:70vh}
}
</style>
</head>
